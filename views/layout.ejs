<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title><%= typeof title !== 'undefined' ? title : 'UnfilteredFaiz' %></title>
  <meta name="description" content="<%= typeof description !== 'undefined' ? description : 'Whispers from Within — a personal blog by Faiz' %>">

  <!-- SEO & Open Graph -->
  <meta property="og:title" content="<%= typeof title !== 'undefined' ? title : 'UnfilteredFaiz' %>">
  <meta property="og:description" content="<%= typeof description !== 'undefined' ? description : 'Whispers from Within' %>">
  <% if (typeof post !== 'undefined' && post && post.cover_image) { %>
    <meta property="og:image" content="<%= post.cover_image %>">
  <% } %>
  <link rel="canonical" href="http://localhost:3000<%= path %>">

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500;1,600&family=Fraunces:ital,opsz,wght@0,9..144,300..900;1,9..144,300..900&family=Lora:ital,wght@0,400..700;1,400..700&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="/css/style.css">

  <!-- Inline theme injection — no FOUC -->
  <script>
    (function() {
      var s = localStorage.getItem('theme');
      if (!s) s = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      document.documentElement.setAttribute('data-theme', s);
    })();
  </script>
  <%- style %>
</head>
<body>
  <%- include('partials/header') %>

  <main class="main-content">
    <%- body %>
  </main>

  <%- include('partials/footer') %>

  <script src="/js/main.js"></script>
  <%- script %>
</body>
</html>

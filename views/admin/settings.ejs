<!-- Top Bar -->
<div class="adm-topbar">
  <a href="/admin/dashboard" class="adm-wordmark">
    <span class="wm-un">un</span><span class="wm-f">filtered</span><span class="wm-aiz">Faiz</span>
  </a>
  <span style="color:var(--adm-border);">|</span>
  <span style="color:var(--adm-muted); font-size:0.8rem; text-transform:uppercase; letter-spacing:1px;">Settings</span>
  <div class="adm-topbar-right">
    <a href="/admin/dashboard" class="adm-btn adm-btn-ghost">← Dashboard</a>
  </div>
</div>

<div class="adm-page" style="max-width: 800px; margin: 0 auto; padding: 2rem 1rem;">
  <form action="/admin/settings" method="POST" enctype="multipart/form-data">
    
    <!-- Row 1: Section Headings -->
    <div style="background:var(--adm-surface); border:1px solid var(--adm-border); border-radius:var(--adm-radius); padding:2rem; margin-bottom:2rem;">
      <h2 style="font-family:var(--font-heading); font-size:1.20rem; margin-bottom:0.5rem; color:var(--adm-text);">Homepage Section Headings</h2>
      <p style="color:var(--adm-muted); font-size:0.85rem; margin-bottom:2rem;">Customize home page section headings.</p>
      
      <div class="form-group">
        <label>Featured Section Heading</label>
        <input type="text" name="heading_featured" class="form-control"
               value="<%= settings.heading_featured || 'Featured' %>" required>
      </div>
      <div class="form-group">
        <label>Categories Section Heading</label>
        <input type="text" name="heading_categories" class="form-control"
               value="<%= settings.heading_categories || 'Explore by Category' %>" required>
      </div>
      <div class="form-group">
        <label>Posts Feed Section Heading</label>
        <input type="text" name="heading_whispers" class="form-control"
               value="<%= settings.heading_whispers || 'Whispers from Within' %>" required>
      </div>
      <div class="form-group">
        <label>Hero Sub-Description Text (Supports HTML & newlines)</label>
        <textarea name="hero_desc" class="form-control" rows="3" required><%= settings.hero_desc !== undefined ? settings.hero_desc : 'Thoughts on life, tech, college days,\nand gazals that breathe at midnight.' %></textarea>
      </div>
    </div>



    <!-- Row 3: Hero Ambient Music Settings -->
    <div style="background:var(--adm-surface); border:1px solid var(--adm-border); border-radius:var(--adm-radius); padding:2rem; margin-bottom:2rem;">
      <h2 style="font-family:var(--font-heading); font-size:1.20rem; margin-bottom:0.5rem; color:var(--adm-text);">Hero Ambient Music</h2>
      <p style="color:var(--adm-muted); font-size:0.85rem; margin-bottom:2rem;">Configure the audio source for the ambient music player. Audio plays globally when toggled.</p>
      
      <div style="margin-bottom: 1.5rem; padding: 1rem; background: rgba(255, 255, 255, 0.02); border: 1px solid var(--adm-border); border-radius: 4px;">
        <span style="font-size: 0.85rem; color: var(--adm-muted); display: block; margin-bottom: 0.25rem;">Currently Active Source:</span>
        <strong style="font-size: 0.9rem; color: var(--accent-color); word-break: break-all;">
          <%= settings.ambient_music_src || 'https://framerusercontent.com/assets/s6Kcvm0lGpVdIimLMjrCJjPgd28.mp3' %>
        </strong>
        <span style="font-size: 0.78rem; color: var(--adm-muted); display: block; margin-top: 0.25rem; font-style: italic;">
          Type: <%= (settings.ambient_music_type || 'file').toUpperCase() %>
        </span>
      </div>

      <div class="form-group">
        <label>Upload Audio File (MP3, WAV, etc.)</label>
        <input type="file" name="audio_file" class="form-control" accept="audio/*">
        <span style="font-size: 0.78rem; color: var(--adm-muted); display: block; margin-top: 0.25rem;">Uploading a file takes precedence over pasting a URL below.</span>
      </div>

      <div class="form-group">
        <label>Or Paste YouTube URL / Audio Link</label>
        <input type="text" name="ambient_music_src_url" class="form-control" placeholder="https://www.youtube.com/watch?v=..."
               value="<%= (settings.ambient_music_src && !settings.ambient_music_src.startsWith('/uploads/')) ? settings.ambient_music_src : '' %>">
        <span style="font-size: 0.78rem; color: var(--adm-muted); display: block; margin-top: 0.25rem;">Supports standard MP3 URLs and YouTube links. YouTube tracks will play hidden in the background.</span>
      </div>

      <div class="form-group" style="display: flex; align-items: center; gap: 0.5rem; margin-top: 1.5rem;">
        <input type="checkbox" id="clear_music_chk" name="clear_music" value="true" style="width: auto; cursor: pointer;">
        <label for="clear_music_chk" style="margin: 0; cursor: pointer; font-weight: normal; color: var(--adm-text);">Reset ambient music to site default MP3 source</label>
      </div>
    </div>

    <!-- Row 4: Hero Image Settings -->
    <div style="background:var(--adm-surface); border:1px solid var(--adm-border); border-radius:var(--adm-radius); padding:2rem; margin-bottom:2rem;">
      <h2 style="font-family:var(--font-heading); font-size:1.20rem; margin-bottom:0.5rem; color:var(--adm-text);">Hero Image</h2>
      <p style="color:var(--adm-muted); font-size:0.85rem; margin-bottom:2rem;">Upload a new image to replace the main hero section image shown on the homepage.</p>
      
      <div style="margin-bottom: 1.5rem; padding: 1rem; background: rgba(255, 255, 255, 0.02); border: 1px solid var(--adm-border); border-radius: 4px; display: flex; flex-direction: column; gap: 0.75rem;">
        <span style="font-size: 0.85rem; color: var(--adm-muted); display: block;">Currently Active Image:</span>
        <div style="max-width: 320px; border-radius: 4px; overflow: hidden; border: 1px solid var(--adm-border);">
          <img src="<%= settings.hero_image || 'https://plus.unsplash.com/premium_photo-1675369532333-a32de6c1e55e?w=900&q=80' %>" 
               alt="Current Hero Image" 
               style="width: 100%; height: 180px; object-fit: cover; display: block;">
        </div>
      </div>

      <div class="form-group">
        <label>Upload New Hero Image (PNG, JPG, WEBP, etc.)</label>
        <input type="file" name="hero_image_file" class="form-control" accept="image/*">
        <span style="font-size: 0.78rem; color: var(--adm-muted); display: block; margin-top: 0.25rem;">Select an image file to upload. It will immediately replace the homepage hero image.</span>
      </div>

      <div class="form-group" style="display: flex; align-items: center; gap: 0.5rem; margin-top: 1.5rem;">
        <input type="checkbox" id="clear_hero_image_chk" name="clear_hero_image" value="true" style="width: auto; cursor: pointer;">
        <label for="clear_hero_image_chk" style="margin: 0; cursor: pointer; font-weight: normal; color: var(--adm-text);">Reset hero image to default placeholder</label>
      </div>
    </div>

    <button type="submit" class="adm-btn adm-btn-primary" style="width: 100%; padding: 0.85rem; font-size: 1rem;">Save All Settings</button>
  </form>

  <!-- Quran Verses Rotation (Outside the main settings form to avoid nested forms) -->
  <div id="quran-verses-section" style="background:var(--adm-surface); border:1px solid var(--adm-border); border-radius:var(--adm-radius); padding:2rem; margin-bottom:2rem; margin-top:2rem;">
    <h2 style="font-family:var(--font-heading); font-size:1.20rem; margin-bottom:0.5rem; color:var(--adm-text);">Footer Quran Verse Pool (Rotating)</h2>
    <p style="color:var(--adm-muted); font-size:0.85rem; margin-bottom:2rem;">
      Manage the pool of Quran verses displayed in the footer. One verse is selected randomly on every refresh. If you leave the translation text blank, the system will automatically fetch it from the public Quran API (alquran.cloud) on the next page load.
    </p>

    <!-- Verses List -->
    <div class="verses-list" style="display:flex; flex-direction:column; gap:1.5rem; margin-bottom:2.5rem;">
      <% verses.forEach((v, index) => { %>
        <div style="background:rgba(255,255,255,0.01); border:1px solid var(--adm-border); border-radius:var(--adm-radius); padding:1.25rem;">
          <form action="/admin/settings/verses/<%= v.id %>/update" method="POST" style="display:flex; flex-direction:column; gap:0.75rem; margin:0;">
            <div style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:0.75rem;">
              <div style="display:flex; align-items:center; gap:0.5rem;">
                <span style="font-weight:600; color:var(--adm-muted); font-size:0.85rem;">#<%= index + 1 %> Reference:</span>
                <input type="text" name="reference" value="<%= v.reference %>" required class="form-control" style="width:100px; display:inline-block; font-weight:600; height:32px; padding:0.25rem 0.5rem;">
              </div>
              <div style="display:flex; gap:0.5rem;">
                <button type="submit" name="action" value="save" class="adm-btn adm-btn-primary" style="padding:0.35rem 0.75rem; font-size:0.75rem; height:32px;">Save</button>
                <button type="submit" name="action" value="delete" class="adm-btn" style="padding:0.35rem 0.75rem; font-size:0.75rem; height:32px; background:#dc3545; color:white; border-color:#dc3545;" onclick="return confirm('Are you sure you want to delete this verse?')">Delete</button>
              </div>
            </div>
            <div>
              <label style="display:block; margin-bottom:0.25rem; font-size:0.8rem; color:var(--adm-muted);">Translation Text:</label>
              <textarea name="text" rows="2" class="form-control" style="font-size:0.85rem; padding:0.5rem;" placeholder="Optional. Leave blank to auto-fetch translation from Quran API..."><%= v.text || '' %></textarea>
            </div>
            <div style="font-size:0.75rem; color:var(--adm-muted); font-style:italic;">
              <%= v.text ? `Status: Cached translation ("${v.surah_name || 'Quran'} ${v.reference}")` : 'Status: Pending API fetch on next visitor load.' %>
            </div>
          </form>
        </div>
      <% }) %>
    </div>

    <!-- Form to add new reference -->
    <form action="/admin/settings/verses/add" method="POST" style="background:rgba(255, 255, 255, 0.02); border:1px solid var(--adm-border); border-radius:var(--adm-radius); padding:1.25rem; margin:0;">
      <h3 style="font-family:var(--font-heading); font-size:1.05rem; margin-bottom:0.5rem; color:var(--adm-text);">Add New Verse Reference</h3>
      <p style="color:var(--adm-muted); font-size:0.8rem; margin-bottom:1rem;">Enter a Surah:Ayah pair (e.g. 94:6, 2:153 or 103:3). The system will fetch the text automatically from the Quran API.</p>
      
      <div style="display:flex; gap:0.75rem; align-items:flex-end; flex-wrap:wrap;">
        <div style="flex:1; min-width:160px;">
          <input type="text" name="reference" placeholder="e.g. 2:286" required class="form-control" style="height:38px;">
        </div>
        <button type="submit" class="adm-btn adm-btn-primary" style="height:38px; padding:0 1.25rem;">Add Reference</button>
      </div>
    </form>
  </div>
</div>

<!-- Top Bar -->
<div class="adm-topbar">
  <a href="/admin/dashboard" class="adm-wordmark">
    <span class="wm-un">unfiltered</span><span class="wm-f">F</span><span class="wm-aiz">aiz</span>
  </a>
  <span style="color:var(--adm-border);">|</span>
  <span style="color:var(--adm-muted); font-size:0.8rem; text-transform:uppercase; letter-spacing:1px;">Categories</span>
  <div class="adm-topbar-right">
    <a href="/admin/dashboard" class="adm-btn adm-btn-ghost">← Dashboard</a>
  </div>
</div>

<div class="adm-page">

  <!-- Add category -->
  <div style="background:var(--adm-surface);border:1px solid var(--adm-border);border-radius:var(--adm-radius);padding:1.75rem;margin-bottom:2rem;">
    <h2 style="font-size:1.1rem;margin-bottom:1.5rem;color:var(--adm-muted);text-transform:uppercase;letter-spacing:1px;font-size:0.8rem;">Add New Category</h2>
    <form action="/admin/categories" method="POST" enctype="multipart/form-data">
      <div style="display:grid;grid-template-columns:1fr 1fr 1fr auto;gap:1rem;align-items:end;">
        <div class="form-group" style="margin:0;">
          <label>Category Name</label>
          <input type="text" name="name" class="form-control" placeholder="e.g. Tech, Gazal…" required>
        </div>
        <div class="form-group" style="margin:0;">
          <label>Image URL (optional)</label>
          <input type="url" name="bg_image_url" class="form-control" placeholder="https://…">
        </div>
        <div class="form-group" style="margin:0;">
          <label>Or Upload Image</label>
          <input type="file" name="bg_image_file" class="form-control" accept="image/*">
        </div>
        <button type="submit" class="adm-btn adm-btn-primary" style="height:42px;">Add</button>
      </div>
    </form>
  </div>

  <!-- Category list -->
  <div class="adm-table-card">
    <% if (categories.length === 0) { %>
      <div style="text-align:center;padding:3rem;color:var(--adm-muted);font-style:italic;">No categories yet.</div>
    <% } else { %>
      <table class="adm-table">
        <thead>
          <tr>
            <th style="width:60px;">Image</th>
            <th>Name</th>
            <th>Slug</th>
            <th>Posts</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% categories.forEach(cat => { %>
            <tr>
              <td>
                <img src="<%= cat.background_image || 'https://images.unsplash.com/photo-1499750310107-5fef28a66643?w=200&q=60' %>"
                     style="width:48px;height:36px;object-fit:cover;border-radius:4px;"
                     onerror="this.src='https://images.unsplash.com/photo-1499750310107-5fef28a66643?w=200&q=60'">
              </td>
              <td class="post-title-cell"><%= cat.name %></td>
              <td class="date-cell"><code style="font-size:0.8rem;"><%= cat.slug %></code></td>
              <td><span class="badge badge-default"><%= cat.post_count %> posts</span></td>
              <td>
                <div class="actions-cell">
                  <button class="adm-edit-link" onclick="openEditModal(<%= cat.id %>, '<%= cat.name %>', '<%= cat.background_image || '' %>')">Edit</button>
                  <form action="/admin/categories/<%= cat.id %>/delete" method="POST" style="display:inline;" onsubmit="return confirm('Delete category \'<%= cat.name %>\'? Posts will be moved to Uncategorized.');">
                    <button type="submit" class="adm-btn adm-btn-danger">Delete</button>
                  </form>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </div>
</div>

<!-- Edit modal -->
<div id="edit-modal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.6);z-index:200;align-items:center;justify-content:center;">
  <div style="background:var(--adm-surface);border:1px solid var(--adm-border);border-radius:var(--adm-radius);padding:2rem;width:100%;max-width:480px;">
    <h3 style="margin-bottom:1.5rem;color:var(--adm-text);">Edit Category</h3>
    <form id="edit-form" method="POST" enctype="multipart/form-data">
      <div class="form-group">
        <label>Name</label>
        <input type="text" name="name" id="edit-name" class="form-control" required>
      </div>
      <div class="form-group">
        <label>Image URL</label>
        <input type="url" name="bg_image_url" id="edit-bg" class="form-control">
        <input type="hidden" name="existing_bg" id="edit-existing-bg">
      </div>
      <div class="form-group">
        <label>Or Upload New Image</label>
        <input type="file" name="bg_image_file" class="form-control" accept="image/*">
      </div>
      <div style="display:flex;gap:0.75rem;justify-content:flex-end;margin-top:1.5rem;">
        <button type="button" onclick="closeEditModal()" class="adm-btn adm-btn-ghost">Cancel</button>
        <button type="submit" class="adm-btn adm-btn-primary">Save Changes</button>
      </div>
    </form>
  </div>
</div>

<script>
  function openEditModal(id, name, bg) {
    document.getElementById('edit-name').value = name;
    document.getElementById('edit-bg').value = bg;
    document.getElementById('edit-existing-bg').value = bg;
    document.getElementById('edit-form').action = '/admin/categories/' + id + '/edit';
    const modal = document.getElementById('edit-modal');
    modal.style.display = 'flex';
  }
  function closeEditModal() {
    document.getElementById('edit-modal').style.display = 'none';
  }
  document.getElementById('edit-modal').addEventListener('click', function(e) {
    if (e.target === this) closeEditModal();
  });
</script>

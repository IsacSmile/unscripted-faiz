<div class="login-page">
  <div class="login-card">
    <a href="/" class="adm-wordmark">
      <span class="wm-un">un</span><span class="wm-f">filtered</span><span class="wm-aiz">Faiz</span>
    </a>
    <p class="login-subtitle">Control Room</p>

    <% if (typeof error !== 'undefined') { %>
      <div class="login-error"><%= error %></div>
    <% } %>

    <form action="/admin/login" method="POST">
      <div class="form-group" style="margin-bottom:1.5rem; text-align:left;">
        <label for="password">Password</label>
        <input
          type="password"
          id="password"
          name="password"
          class="form-control"
          placeholder="Enter your password"
          autocomplete="current-password"
          required>
      </div>
      <button type="submit" class="adm-btn adm-btn-primary" style="width:100%; justify-content:center; padding:0.8rem;">
        Sign In
      </button>
    </form>

    <p style="margin-top:2rem; font-size:0.8rem; color:var(--adm-muted);">
      <a href="/home" style="color:var(--adm-muted); text-decoration:none;">← Back to site</a>
    </p>
  </div>
</div>

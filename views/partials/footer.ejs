<!-- Centered Share Modal -->
<div id="share-modal-backdrop" class="share-modal-backdrop"></div>
<div id="share-modal" class="share-modal" role="dialog" aria-modal="true" aria-labelledby="share-modal-title">
  <div class="share-modal-header">
    <h3 id="share-modal-title">Share this post</h3>
    <button id="share-modal-close" class="share-modal-close-btn" aria-label="Close modal">&times;</button>
  </div>
  <div class="share-modal-body">
    <button class="share-modal-opt" id="share-opt-twitter">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
